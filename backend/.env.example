# Database
DATABASE_URL="mysql://user:password@localhost:3306/modavance"

# JWT (use long random strings in production)
JWT_SECRET="change-me-to-a-long-random-string-32chars-min"
JWT_EXPIRES_IN="7d"
ADMIN_JWT_SECRET="change-me-to-a-different-long-random-string-32chars"
ADMIN_JWT_EXPIRES_IN="1d"

# Admin credentials (used by seed script)
ADMIN_EMAIL="admin@modavance.com"
ADMIN_PASSWORD="change-me-in-production"

# App
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
